<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected state (Active Bar) -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/highlight" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="@color/accent_vibrant" />
        </shape>
    </item>
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/secondary_dark" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="#444444" />
        </shape>
    </item>
</selector>
